{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoarchdx.dev/schema/manifest/1.0/manifest.schema.json",
  "title": "AutoArchDX manifest",
  "description": "Generated architecture manifest produced by the AutoArchDX scanner.",
  "type": "object",
  "required": ["version", "scanner_version", "generated", "project", "root", "nodes", "edges", "groups", "warnings"],
  "additionalProperties": false,

  "properties": {

    "version": {
      "type": "string",
      "description": "Manifest schema version.",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "examples": ["1.0"]
    },

    "scanner_version": {
      "type": "string",
      "description": "Semver version of the scanner that produced this manifest.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$",
      "examples": ["0.1.0"]
    },

    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the scan ran."
    },

    "project": {
      "type": "string",
      "description": "Project name.",
      "minLength": 1
    },

    "root": {
      "type": "string",
      "description": "Relative path to the repository root from the manifest file location.",
      "examples": ["./"]
    },

    "repo_url": {
      "type": "string",
      "format": "uri",
      "description": "Repository URL. Used by the renderer to generate source file links."
    },

    "description": {
      "type": "string",
      "description": "Short human description of the project."
    },

    "upstream": {
      "$ref": "#/$defs/upstream",
      "description": "Present only in forked repositories."
    },

    "nodes": {
      "type": "array",
      "description": "Declared architectural components.",
      "items": { "$ref": "#/$defs/node" }
    },

    "edges": {
      "type": "array",
      "description": "Connections between components.",
      "items": { "$ref": "#/$defs/edge" }
    },

    "groups": {
      "type": "array",
      "description": "Logical groupings of components.",
      "items": { "$ref": "#/$defs/group" }
    },

    "warnings": {
      "type": "array",
      "description": "Diagnostic entries produced during the scan. Never fatal.",
      "items": { "$ref": "#/$defs/warning" }
    }

  },

  "$defs": {

    "node_type": {
      "type": "string",
      "enum": ["platform", "api", "db", "client", "datasrc", "partner", "group"]
    },

    "status": {
      "type": "string",
      "enum": ["built", "partial", "planned", "undef"]
    },

    "source_origin": {
      "type": "string",
      "enum": ["annotation", "yaml", "inferred", "both"]
    },

    "symbol_kind": {
      "type": "string",
      "enum": [
        "function", "method", "struct", "class", "interface",
        "type", "variable", "constant", "module", "package", "unknown"
      ]
    },

    "layout_xy": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },

    "layout_xywh": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    },

    "ci_context": {
      "type": "object",
      "description": "GitHub Actions context. Present only when manifest is generated by the Action.",
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string" },
        "workflow": { "type": "string" },
        "triggered_by": {
          "type": "string",
          "enum": ["push", "pull_request", "workflow_dispatch", "schedule"]
        },
        "pr_number": {
          "type": ["integer", "null"]
        }
      }
    },

    "annotation_provenance_entry": {
      "type": "object",
      "description": "Provenance for a single @arch:* annotation contributing to a component.",
      "required": ["source", "file", "line"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "annotation" },
        "file": {
          "type": "string",
          "description": "Path relative to repo root."
        },
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number of the @arch: tag."
        },
        "symbol": {
          "type": "string",
          "description": "Name of the symbol immediately following the annotation."
        },
        "symbol_kind": {
          "$ref": "#/$defs/symbol_kind",
          "description": "Kind of the symbol following the annotation."
        },
        "annotation": {
          "type": "string",
          "description": "Raw annotation string as it appears in source."
        },
        "commit": {
          "type": "string",
          "description": "Full SHA of the commit where this annotation was last modified."
        },
        "introduced_at": {
          "type": "string",
          "description": "Full SHA of the commit where this annotation first appeared."
        },
        "committed_at": {
          "type": "string",
          "format": "date-time"
        },
        "branch": {
          "type": "string",
          "description": "Branch name at time of scan."
        },
        "author": {
          "type": "string",
          "description": "From git blame at file:line."
        },
        "ci": { "$ref": "#/$defs/ci_context" }
      }
    },

    "annotation_provenance": {
      "description": "Provenance for annotation-sourced elements. Single object when one annotation; array when multiple annotations share the same id.",
      "oneOf": [
        { "$ref": "#/$defs/annotation_provenance_entry" },
        {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/annotation_provenance_entry" }
        }
      ]
    },

    "yaml_provenance": {
      "type": "object",
      "description": "Provenance for elements declared in YAML definition files.",
      "required": ["source", "file", "yaml_key"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "yaml" },
        "file": {
          "type": "string",
          "description": "Path relative to repo root."
        },
        "yaml_key": {
          "type": "string",
          "description": "Pointer into the definition file. Format: section[index].",
          "examples": ["components[0]", "connections[3]", "groups[1]"]
        },
        "commit": { "type": "string" },
        "introduced_at": { "type": "string" },
        "committed_at": { "type": "string", "format": "date-time" },
        "branch": { "type": "string" },
        "author": { "type": "string" },
        "ci": { "$ref": "#/$defs/ci_context" }
      }
    },

    "inferred_provenance": {
      "type": "object",
      "description": "Provenance for edges produced by import graph analysis.",
      "required": ["source", "import_path"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "inferred" },
        "import_path": {
          "type": "string",
          "description": "The import statement that produced this edge."
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "commit": { "type": "string" },
        "branch": { "type": "string" }
      }
    },

    "dual_provenance": {
      "type": "object",
      "description": "Provenance for elements declared in both annotation and YAML. Present when source is 'both'.",
      "required": ["annotation", "yaml"],
      "additionalProperties": false,
      "properties": {
        "annotation": { "$ref": "#/$defs/annotation_provenance" },
        "yaml": { "$ref": "#/$defs/yaml_provenance" }
      }
    },

    "provenance": {
      "description": "Provenance for a manifest element. Shape determined by source field.",
      "oneOf": [
        { "$ref": "#/$defs/annotation_provenance" },
        { "$ref": "#/$defs/yaml_provenance" },
        { "$ref": "#/$defs/inferred_provenance" },
        { "$ref": "#/$defs/dual_provenance" }
      ]
    },

    "node": {
      "type": "object",
      "description": "A declared architectural component.",
      "required": ["id", "type", "status", "label", "source", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable slug. Lowercase kebab-case when set explicitly.",
          "minLength": 1
        },
        "type": { "$ref": "#/$defs/node_type" },
        "status": { "$ref": "#/$defs/status" },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Merged union from all sources."
        },
        "group": {
          "description": "Group membership. String for single group, array for multiple.",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "layout": { "$ref": "#/$defs/layout_xy" },
        "source": { "$ref": "#/$defs/source_origin" },
        "origin": {
          "type": "string",
          "enum": ["local", "upstream", "fork-override", "fork-extended"],
          "description": "Fork manifests only. Relationship of this node to the upstream manifest."
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },

    "edge": {
      "type": "object",
      "description": "A connection between two components.",
      "required": ["id", "from", "to", "kind", "bidir", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Generated. Format: e:<from>-><to>. Multiple edges between same pair append :2, :3, etc.",
          "minLength": 1
        },
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["declared", "inferred", "override"]
        },
        "bidir": { "type": "boolean" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "origin": {
          "type": "string",
          "enum": ["local", "upstream", "fork-override", "fork-extended"],
          "description": "Fork manifests only. Relationship of this edge to the upstream manifest."
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },

    "group": {
      "type": "object",
      "description": "A logical grouping of components. Renders as a dashed container.",
      "required": ["id", "label", "members", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "members": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Node IDs. Merged from all sources."
        },
        "layout": { "$ref": "#/$defs/layout_xywh" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },

    "warning": {
      "type": "object",
      "description": "A diagnostic entry produced during the scan.",
      "required": ["code", "severity", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "SOT_CONFLICT",
            "SOT_OVERRIDE",
            "SOT_DUAL_OVERRIDE",
            "SOT_DEFERRED",
            "MISSING_ID",
            "MISSING_IMPL",
            "BROKEN_REF",
            "AMBIGUOUS_REF",
            "DUPLICATE_ID",
            "ORPHANED_NODE",
            "STALE_ANNOTATION",
            "SHALLOW_CLONE"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["warn", "info"]
        },
        "message": { "type": "string" },
        "node_id": { "type": "string" },
        "edge_id": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolution": {
          "type": "string",
          "enum": ["annotation", "yaml"]
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },

    "upstream": {
      "type": "object",
      "description": "Upstream reference for forked repositories.",
      "required": ["repo_url", "manifest_ref"],
      "additionalProperties": false,
      "properties": {
        "repo_url": {
          "type": "string",
          "format": "uri"
        },
        "manifest_ref": {
          "type": "string",
          "description": "Commit SHA of the upstream manifest used as the base layer."
        },
        "merged_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }

  }
}
